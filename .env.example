# =============================================================================
#  .env.example — template de variáveis de ambiente do projeto SMPI
#  Copie para .env e preencha os valores antes de rodar.
#
#  DESENVOLVIMENTO: use os valores padrão abaixo.
#  PRODUÇÃO: ajuste os valores marcados com [PROD] e use Docker Secrets
#            para senhas (smpi_db_password, smpi_redis_password, etc.).
# =============================================================================

# --- Django ---
SECRET_KEY=django-insecure-change-me-before-production-use
DEBUG=True
# [PROD] DEBUG=False

# [PROD] ALLOWED_HOSTS=www.techteo.com.br,techteo.com.br,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,app

# [PROD] CSRF_TRUSTED_ORIGINS=https://www.techteo.com.br,https://techteo.com.br
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Domínio (usado no stack.yml / Traefik) ---
# [PROD] DOMAIN=www.techteo.com.br
DOMAIN=localhost

# --- Localizacao ---
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br

# --- Banco de dados (PostgreSQL) ---
POSTGRES_DB=smpi
POSTGRES_USER=smpi
POSTGRES_PASSWORD=change_me
# [PROD] POSTGRES_PASSWORD vem do Docker Secret smpi_db_password (não setar aqui)
POSTGRES_HOST=localhost
# [PROD] POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
DATABASE_URL=postgresql://smpi:change_me@localhost:5432/smpi
# [PROD] DATABASE_URL não é necessário; settings.py reconstrói a partir dos secrets

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=smpi
RABBITMQ_DEFAULT_PASS=change_me
# [PROD] RABBITMQ_DEFAULT_PASS vem do Docker Secret smpi_rabbit_password
RABBITMQ_HOST=localhost
# [PROD] RABBITMQ_HOST=rabbitmq
RABBITMQ_URL=amqp://smpi:change_me@localhost:5672/

# --- Celery / Redis ---
CELERY_BROKER_URL=amqp://smpi:change_me@localhost:5672/
# [PROD] CELERY_BROKER_URL reconstruído a partir dos secrets em settings.py
CELERY_RESULT_BACKEND=redis://:change_me@localhost:6379/0
# [PROD] CELERY_RESULT_BACKEND reconstruído a partir dos secrets
REDIS_URL=redis://:change_me@localhost:6379/1
REDIS_PASSWORD=change_me
# [PROD] REDIS_PASSWORD vem do Docker Secret smpi_redis_password
REDIS_HOST=localhost
# [PROD] REDIS_HOST=redis

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8080
# [PROD] EVOLUTION_API_URL=http://evolution_api:8080
EVOLUTION_API_KEY=smpi-evolution-key-2024
# [PROD] EVOLUTION_API_KEY vem do Docker Secret smpi_evolution_key
EVOLUTION_INSTANCE=smpi
EVOLUTION_REDIS_PASSWORD=change_me
# [PROD] EVOLUTION_REDIS_PASSWORD vem do Docker Secret smpi_evolution_redis_password

# --- IA / LLM ---
OPENAI_API_KEY=sk-...
# [PROD] OPENAI_API_KEY vem do Docker Secret smpi_openai_key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDINGS_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=

# --- E-mail (SMTP) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# [PROD] EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=change_me

# --- Imagem Docker (para deploy) ---
# [PROD single-node]  IMAGE=smpi_app:latest (default, sem push)
# [PROD multi-node]   IMAGE=ghcr.io/usuario/smpi_v1:latest (com push)
IMAGE=smpi_app:latest
